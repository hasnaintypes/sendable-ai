{
  "name": "sendable-ai",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "run-p -r \"dev:*\"",
    "dev:frontend": "next dev --webpack --experimental-https",
    "dev:backend": "convex dev --typecheck-components",
    "dev:build": "chokidar 'tsconfig*.json' 'src/**/*.ts' 'src/**/*.tsx' -i '**/*.test.ts' -c 'npm run build' --initial",
    "predev": "convex dev --skip-push && node -e \"if (!require('fs').existsSync('dist')) require('fs').mkdirSync('dist', { recursive: true })\"",
    "build": "convex codegen && next build",
    "lint": "next lint && tsc -p convex && eslint convex"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.10",
    "@convex-dev/resend": "^0.1.4",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@react-email/components": "0.5.0",
    "better-auth": "^1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "convex-helpers": "^0.1.87",
    "http-proxy-middleware": "^3.0.5",
    "jose": "^6.1.2",
    "lucide-react": "^0.486.0",
    "next": "^16.0.5",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-qr-code": "^2.0.15",
    "resend": "^4.2.0",
    "shadcn": "^2.4.0-canary.17",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.1.0",
    "tw-animate-css": "^1.2.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.0.17",
    "@types/node": "^20",
    "@types/react": "^19.2.10",
    "baseline-browser-mapping": "^2.8.32",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.2.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.0.17",
    "typescript": "^5"
  }
}
