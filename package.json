{
  "name": "sendable-ai",
  "version": "0.1.0",
  "packageManager": "pnpm@9.14.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "run-p -r \"dev:*\"",
    "dev:frontend": "next dev --webpack --experimental-https",
    "dev:backend": "convex dev --typecheck-components",
    "dev:build": "chokidar 'tsconfig*.json' 'src/**/*.ts' 'src/**/*.tsx' -i '**/*.test.ts' -c 'pnpm build' --initial",
    "predev": "convex dev --skip-push && node -e \"if (!require('fs').existsSync('dist')) require('fs').mkdirSync('dist', { recursive: true })\"",
    "build": "convex codegen && next build",
    "lint": "next lint && tsc -p convex && eslint convex",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"convex/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"convex/**/*.{ts,js}\""
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.13",
    "@convex-dev/resend": "^0.1.13",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "0.5.0",
    "better-auth": "1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.114",
    "framer-motion": "^12.35.0",
    "http-proxy-middleware": "^3.0.5",
    "jose": "^6.1.3",
    "lenis": "^1.3.18",
    "lucide-react": "^0.486.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-qr-code": "^2.0.18",
    "resend": "^4.8.0",
    "shadcn": "^2.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.19.35",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "baseline-browser-mapping": "^2.10.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "15.2.3",
    "nodemailer": "^8.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk": ">=1.25.4",
      "hono": "^4.12.4",
      "@hono/node-server": "^1.19.10",
      "lodash": "^4.17.23"
    }
  }
}